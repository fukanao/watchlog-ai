OLLAMA_URL=http://10.0.4.101:11534
OLLAMA_MODEL=gpt-oss:120b
SLACK_WEBHOOK_URL=

# Development: logs
# Production: /var/log/znw-support-ai-flask
LOG_DIR=logs
LOG_FILES=access.log,error.log
STATE_FILE=.watchlog-ai-state.json
CHECK_INTERVAL_SECONDS=300
START_AT_END=false
CHUNK_MAX_LINES=160
OLLAMA_TIMEOUT_SECONDS=120

# Optional Raspberry Pi or another webhook receiver.
RASPI_WEBHOOK_URL=

# Optional email notification.
EMAIL_ENABLED=false
SMTP_HOST=
SMTP_PORT=587
SMTP_USE_TLS=true
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=
SMTP_TO=

# Set true when testing notifications locally.
DRY_RUN=false

